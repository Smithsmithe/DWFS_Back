{
  "info": {
    "name": "Book Catalogue API",
    "_postman_id": "book-catalogue-api-v1",
    "description": "Colección de pruebas para el microservicio book catalogue",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8081/api/books/v1"
    }
  ],
  "item": [
    {
      "name": "GET - All Books",
      "request": {
        "method": "GET",
        "header": [],
        "url": "{{baseUrl}}"
      }
    },
    {
      "name": "GET - Book By ID",
      "request": {
        "method": "GET",
        "header": [],
        "url": "{{baseUrl}}/1"
      }
    },
    {
      "name": "GET - Search By Author",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}?author=rowling",
          "host": ["{{baseUrl}}"],
          "query": [
            {
              "key": "author",
              "value": "Emily"
            }
          ]
        }
      }
    },
    {
      "name": "GET - Search Combined",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}?category=fantasy&visible=true&rating=4.0",
          "host": ["{{baseUrl}}"],
          "query": [
            {
              "key": "category",
              "value": "fantasy"
            },
            {
              "key": "visible",
              "value": "true"
            },
            {
              "key": "rating",
              "value": "4.0"
            }
          ]
        }
      }
    },
    {
      "name": "GET - Pagination",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/paged?page=0&size=10",
          "host": ["{{baseUrl}}"],
          "path": ["paged"],
          "query": [
            {
              "key": "page",
              "value": "0"
            },
            {
              "key": "size",
              "value": "10"
            }
          ]
        }
      }
    },
    {
      "name": "POST - Create Book",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"title\": \"Clean Code\",\n  \"author\": \"Robert C. Martin\",\n  \"shortDescription\": \"Software engineering best practices\",\n  \"fullDescription\": \"A handbook of agile software craftsmanship.\",\n  \"isbn\": \"9780132350884\",\n  \"category\": \"Software\",\n  \"publicationDate\": \"2008-08-01\",\n  \"language\": \"English\",\n  \"editorial\": \"Prentice Hall\",\n  \"pages\": 464,\n  \"rating\": 4.8,\n  \"format\": \"Paperback\",\n  \"price\": 59.99,\n  \"stock\": 10,\n  \"visible\": true,\n  \"imageUrls\": [\n    \"https://example.com/clean-code-1.jpg\",\n    \"https://example.com/clean-code-2.jpg\"\n  ]\n}"
        },
        "url": "{{baseUrl}}"
      }
    },
    {
      "name": "PUT - Update Book",
      "request": {
        "method": "PUT",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"title\": \"Clean Code Updated\",\n  \"author\": \"Robert C. Martin\",\n  \"shortDescription\": \"Updated description\",\n  \"fullDescription\": \"Updated full description.\",\n  \"isbn\": \"9780132350884\",\n  \"category\": \"Software\",\n  \"publicationDate\": \"2008-08-01\",\n  \"language\": \"English\",\n  \"editorial\": \"Prentice Hall\",\n  \"pages\": 464,\n  \"rating\": 4.9,\n  \"format\": \"Hardcover\",\n  \"price\": 69.99,\n  \"stock\": 15,\n  \"visible\": true,\n  \"imageUrls\": [\n    \"https://example.com/updated-1.jpg\"\n  ]\n}"
        },
        "url": "{{baseUrl}}/1"
      }
    },
    {
      "name": "PATCH - Partial Update",
      "request": {
        "method": "PATCH",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"price\": 39.99,\n  \"stock\": 20,\n  \"visible\": false,\n  \"rating\": 4.7\n}"
        },
        "url": "{{baseUrl}}/1"
      }
    },
    {
      "name": "DELETE - Book",
      "request": {
        "method": "DELETE",
        "header": [],
        "url": "{{baseUrl}}/1"
      }
    },
    {
      "name": "GET - Not Found Test",
      "request": {
        "method": "GET",
        "header": [],
        "url": "{{baseUrl}}/99999"
      }
    }
  ]
}